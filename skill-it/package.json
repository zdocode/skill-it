{
  "name": "skill-it",
  "version": "2.0.0",
  "description": "Secure, AI-powered job search pipeline with hardened security controls",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "skill-it": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "doctor": "node dist/doctor.js",
    "verify": "node dist/verify-security.js",
    "verify-security": "node dist/verify-security.js",
    "harden": "node dist/scripts/harden.js",
    "migrate": "node dist/scripts/migrate.js",
    "test": "jest --coverage",
    "test:security": "jest test/security --coverage",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write src/",
    "audit": "npm audit --audit-level=high && npx license-checker --summary",
    "prepublishOnly": "npm run build && npm test && npm run verify"
  },
  "keywords": [
    "job-search",
    "career",
    "ai",
    "security",
    "pdf-generation",
    "scraper",
    "tracker"
  ],
  "author": "Security-Focused Developer <security@example.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "zod": "^3.22.4",
    "js-yaml": "^4.1.0",
    "sanitize-html": "^2.11.0",
    "better-sqlite3": "^9.2.2",
    "playwright": "^1.40.1",
    "@anthropic-ai/sdk": "^0.24.3",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.12",
    "date-fns": "^2.30.0",
    "node-fetch": "^3.3.2",
    "winston": "^3.11.0",
    "rotating-file-stream": "^3.0.0",
    "hash-it": "^7.0.2",
    "uuid": "^9.0.1",
    "pino": "^8.17.2",
    "cli-table3": "^0.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/better-sqlite3": "^7.6.9",
    "@types/js-yaml": "^4.0.9",
    "@types/sanitize-html": "^2.9.0",
    "@types/inquirer": "^9.0.7",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.1.1"
  },
  "overrides": {
    "playwright": {
      "chrome": "99.0.4844.84"
    }
  },
  "files": [
    "dist/",
    "templates/",
    "fonts/",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourname/skill-it.git"
  },
  "bugs": {
    "url": "https://github.com/yourname/skill-it/issues"
  },
  "security": {
    "contact": "security@example.com"
  }
}
